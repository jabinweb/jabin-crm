# Database
DATABASE_URL="postgresql://username:password@localhost:5432/leadgen?schema=public&connection_limit=10&pool_timeout=20"
# Optional: Direct connection URL for Prisma Migrate (bypasses connection pooling)
DIRECT_URL="postgresql://username:password@localhost:5432/leadgen?schema=public"
# Hosted Postgres (e.g. Neon) often uses sslmode=require. Node's `pg` driver may log a future-compat
# warning: either set sslmode=verify-full in the URL, or add uselibpqcompat=true&sslmode=require
# (see https://www.postgresql.org/docs/current/libpq-ssl.html).

# NextAuth.js (Auth.js v5 — https://authjs.dev)
# Generate: npx auth secret
AUTH_SECRET="your-nextauth-secret-here-minimum-32-characters"
# Must match the browser URL when set (custom domain). Omit on Vercel to use trustHost for OAuth.
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Google OAuth — redirect URI: {AUTH_URL or site URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Encryption (for sensitive data in database)
ENCRYPTION_KEY="your-encryption-key-here-minimum-32-characters"

# Email Service Provider (resend, sendgrid, smtp)
EMAIL_PROVIDER="smtp"
EMAIL_API_KEY="your-email-api-key-here"

# Email Configuration (for SMTP with Nodemailer)
# For Gmail: smtp.gmail.com, port 587, secure=false
# For SendGrid: smtp.sendgrid.net, port 587
# For Outlook: smtp-mail.outlook.com, port 587
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="your-email@gmail.com"

# IMAP Configuration (for checking replies)
IMAP_HOST="imap.gmail.com"
IMAP_PORT=993
IMAP_USER="your-email@gmail.com"
IMAP_PASSWORD="your-app-password"
IMAP_TLS="true"

# Inbound email webhook (email-to-ticket). Set a strong secret; providers send it as
# Authorization: Bearer <secret> or x-webhook-secret header.
# These routes are intentionally public (no login / no plan check):
#   POST /api/emails/webhook/inbound  — optional secret via INBOUND_EMAIL_WEBHOOK_SECRET
#   POST /api/emails/reply            — optional secret via INBOUND_EMAIL_WEBHOOK_SECRET (same as inbound)
#   GET  /api/emails/track/open/[id]  — open tracking pixel
#   GET  /api/emails/track/click/[id] — click redirect + tracking
INBOUND_EMAIL_WEBHOOK_SECRET="your-inbound-email-webhook-secret"

# Redis (recommended in production for distributed API rate limiting)
REDIS_URL="redis://default:password@redis.example.com:6379"

# Staging only — allow admin to mark payslips paid without Razorpay (never in production)
ALLOW_MANUAL_PAYROLL_MARK_PAID="false"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Payment Gateway (Razorpay)
RAZORPAY_ENV="test"
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_TEST_KEY_ID="your-razorpay-test-key-id"
RAZORPAY_TEST_KEY_SECRET="your-razorpay-test-key-secret"
RAZORPAY_LIVE_KEY_ID="your-razorpay-live-key-id"
RAZORPAY_LIVE_KEY_SECRET="your-razorpay-live-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"
# From Razorpay Dashboard → Webhooks. Required for subscription/payroll webhooks (warn-only at boot if missing).

# Regional pricing (PPP) — geo from Vercel (x-vercel-ip-country) or Cloudflare (cf-ipcountry)
# Users can override via pricing page; stored in pricing_country cookie
# Display currency + FX rates: lib/pricing/currency.ts (update INR_EXCHANGE_RATES periodically)
# Checkout still settles in INR via Razorpay
PPP_DEFAULT_COUNTRY="IN"

# Cron / background jobs (protect /api/cron/* and /api/jobs/*)
CRON_SECRET="your-cron-secret-min-16-chars"
# Warn-only at boot if missing; cron routes stay disabled until set.
CRON_API_KEY="your-cron-api-key"

# Optional webhook for production error alerts (Slack, Discord, PagerDuty, etc.)
ERROR_WEBHOOK_URL=""

# File uploads (optional — defaults to external PHP endpoint if unset)
NEXT_PUBLIC_PHP_UPLOAD_URL="https://your-cdn.example.com/upload.php"

# WebRTC calls (optional STUN servers, comma-separated)
NEXT_PUBLIC_STUN_SERVERS="stun:stun.l.google.com:19302"

# API Keys for Lead Generation
GOOGLE_PLACES_API_KEY="your-google-places-api-key"
GEMINI_API_KEY="your-gemini-api-key"
OPENAI_API_KEY="your-openai-api-key"

# Rate Limiting (Optional - defaults shown)
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"

# Scraping Configuration
SCRAPING_RATE_LIMIT=10
SCRAPING_CONCURRENT_LIMIT=3
SCRAPING_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# Application Settings
NEXT_PUBLIC_APP_NAME="Opslane"
NEXT_PUBLIC_SUPPORT_TEAM_NAME="Your Company Support"
NEXT_PUBLIC_SYSTEM_NAME="Your Company System"
NEXT_PUBLIC_APP_LOGO_URL=""
NEXT_PUBLIC_BRAND_PRIMARY="#2563eb"
# Workspace URLs: path (default) = yourapp.com/acme — subdomain = acme.yourapp.com (needs custom domain + wildcard DNS)
NEXT_PUBLIC_TENANCY_MODE="path"
MAX_LEADS_PER_SCRAPING_JOB=1000
MAX_CAMPAIGNS_PER_USER=50
MAX_EMAILS_PER_CAMPAIGN=10000
NODE_ENV="development"  # or "production"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_WHATSAPP_FROM="+14155238886"

# Security Notes:
# 1. NEVER commit the actual .env file to git
# 2. Generate strong random secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. Use app-specific passwords for Gmail (not your main password)
# 4. Rotate secrets regularly in production
# 5. Use environment variables from your hosting platform in production
