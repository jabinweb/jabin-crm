generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/** Singleton platform knobs (id = "default"). Env is fallback when unset. */
model PlatformSetting {
  id          String   @id @default("default")
  /** path | subdomain */
  tenancyMode String   @default("path")
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                  String                  @id @default(cuid())
  name                String?
  email               String                  @unique
  emailVerified       DateTime?
  image               String?
  role                UserRole                @default(SALES)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  customerId          String?
  accounts            Account[]
  auditLogs           AuditLog[]
  calendarEvents      CalendarEvent[]
  assignedDeals       Deal[]                  @relation("DealAssignee")
  deals               Deal[]                  @relation("DealCreator")
  emailCampaigns      EmailCampaign[]
  emailDrafts         EmailDraft[]
  emailLogs           EmailLog[]
  sequences           EmailSequence[]
  emailTemplates      EmailTemplate[]
  files               File[]
  invoices            Invoice[]
  assignedLeads       Lead[]                  @relation("LeadAssignee")
  leads               Lead[]                  @relation("LeadCreator")
  leadActivities      LeadActivity[]
  quotations          Quotation[]
  serviceReports      ServiceReport[]         @relation("ServiceReports")
  sessions            Session[]
  subscription        Subscription?
  assignedTickets     SupportTicket[]         @relation("AssignedTickets")
  assignedTasks       Task[]                  @relation("TaskAssignee")
  tasks               Task[]                  @relation("TaskCreator")
  ticketActivities    TicketActivity[]        @relation("TicketActivities")
  transfersFrom       TicketTransferHistory[] @relation("TransfersFrom")
  transfersTo         TicketTransferHistory[] @relation("TransfersTo")
  usage               UsageTracking?
  customer            Customer?               @relation("CustomerStaff", fields: [customerId], references: [id])
  profile             UserProfile?
  userRoles           UserRoleAssignment[]
  workflows           Workflow[]
  notifications       Notification[]
  cashEntries         CashOnHandEntry[]       @relation("CashEntryCreator")
  cashAssignments     CashOnHandEntry[]       @relation("CashTechnician")
  travelExpenses      TravelExpense[]         @relation("TechnicianExpenses")
  approvedExpenses    TravelExpense[]         @relation("ExpenseApprover")
  submittedExpenses   TravelExpense[]         @relation("ExpenseCreator")
  supportGroupMembers SupportGroupMember[]
  locationLogs        TechnicianLocationLog[] @relation("TechnicianLocations")
  whatsappConfig      WhatsAppProviderConfig?
  whatsappMessages    WhatsAppMessage[]
  featureModules      FeatureModuleSetting[]

  // ── Company Management Integration ──
  password         String?
  userStatus       UserStatus        @default(ACTIVE)
  companyId        String?
  primaryCompanyId String?
  managedCompanyId String?
  lastSeenAt       DateTime?
  company          Company?          @relation("UserCompany", fields: [companyId], references: [id])
  primaryCompany   Company?          @relation("UserPrimaryCompany", fields: [primaryCompanyId], references: [id])
  managedCompany   Company?          @relation("CompanyManager", fields: [managedCompanyId], references: [id])
  employeeProfile  Employee?         @relation("UserEmployee")
  userCompanies    UserCompany[]
  companyRoles     UserCompanyRole[]
  userSessions     UserSession[]
  userSettings     UserSettings?
  employeeSalaries EmployeeSalary[]

  @@index([companyId])
  @@index([primaryCompanyId])
  @@index([managedCompanyId])
}

model UserProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  companyName         String?
  industry            String?
  companySize         String?
  website             String?
  description         String?
  service             String?
  targetAudience      String?
  valueProposition    String?
  companyEmail        String?
  useAdminEmail       Boolean  @default(true)
  smtpHost            String?
  smtpPort            Int?     @default(587)
  smtpSecure          Boolean? @default(false)
  smtpUser            String?
  smtpPassword        String?
  smtpFrom            String?
  imapHost            String?
  imapPort            Int?     @default(993)
  imapSecure          Boolean? @default(true)
  imapUser            String?
  imapPassword        String?
  geminiApiKey        String?
  googlePlacesApiKey  String?
  aiModel             String?  @default("gemini-2.5-flash")
  preferredCurrency   String?  @default("USD")
  companyAddress      String?
  companyPhone        String?
  taxId               String?
  invoicePrefix       String?  @default("INV")
  quotationPrefix     String?  @default("QT")
  invoiceTerms        String?
  quotationTerms      String?
  bankName            String?
  accountName         String?
  accountNumber       String?
  routingNumber       String?
  swiftCode           String?
  iban                String?
  paymentInstructions String?
  templateStyle       String?  @default("modern")
  primaryColor        String?  @default("#2563eb")
  secondaryColor      String?  @default("#7c3aed")
  logoUrl             String?
  headerText          String?
  footerText          String?
  isComplete          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id                String            @id @default(cuid())
  companyName       String
  website           String?
  email             String?
  phone             String?
  address           String?
  city              String?
  state             String?
  country           String?
  zipCode           String?
  latitude          Float?
  longitude         Float?
  industry          String?
  employeeCount     Int?
  revenue           String?
  contactName       String?
  name              String?
  jobTitle          String?
  linkedinUrl       String?
  twitterUrl        String?
  facebookUrl       String?
  instagramUrl      String?
  rating            Float?
  reviewCount       Int?
  description       String?
  source            String
  sourceUrl         String?
  priority          Priority          @default(MEDIUM)
  sourceType        CompanyLeadSource @default(WEBSITE)
  userId            String
  assignedToId      String?
  employeeId        String?
  companyId         String?
  status            LeadStatus        @default(NEW)
  isVerified        Boolean           @default(false)
  isEnriched        Boolean           @default(false)
  tags              String[]          @default([])
  notes             String?
  lastContactedAt   DateTime?
  convertedAt       DateTime?
  convertedClientId String?           @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  calendarEvents      CalendarEvent[]
  contacts            Contact[]
  deals               Deal[]
  emailCampaignLeads  EmailCampaignLead[]
  emailLogs           EmailLog[]
  invoices            Invoice[]
  assignedTo          User?                @relation("LeadAssignee", fields: [assignedToId], references: [id])
  employee            Employee?            @relation("EmployeeAssignedLeads", fields: [employeeId], references: [id])
  company             Company?             @relation("CompanyLeads", fields: [companyId], references: [id])
  user                User                 @relation("LeadCreator", fields: [userId], references: [id], onDelete: Cascade)
  activities          LeadActivity[]
  enrichmentData      LeadEnrichment?
  score               LeadScore?
  quotations          Quotation[]
  sequenceEnrollments SequenceEnrollment[]
  tasks               Task[]
  whatsappMessages    WhatsAppMessage[]
  convertedClient     Client?              @relation("ClientConvertedLead", fields: [convertedClientId], references: [id])
  documents           LeadDocument[]

  @@index([companyName])
  @@index([industry])
  @@index([userId])
  @@index([assignedToId])
  @@index([status])
  @@index([createdAt])
}

model LeadEnrichment {
  id               String   @id @default(cuid())
  leadId           String   @unique
  companySize      String?
  yearFounded      Int?
  technologies     String[] @default([])
  socialProfiles   Json?
  businessHours    Json?
  additionalEmails String[] @default([])
  additionalPhones String[] @default([])
  enrichedAt       DateTime @default(now())
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model EmailCampaign {
  id                 String              @id @default(cuid())
  name               String
  subject            String
  emailTemplate      String
  fromName           String
  fromEmail          String
  replyTo            String?
  status             CampaignStatus      @default(DRAFT)
  scheduledAt        DateTime?
  sentAt             DateTime?
  userId             String
  totalRecipients    Int                 @default(0)
  sentCount          Int                 @default(0)
  openCount          Int                 @default(0)
  clickCount         Int                 @default(0)
  replyCount         Int                 @default(0)
  bounceCount        Int                 @default(0)
  unsubscribeCount   Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailCampaignLeads EmailCampaignLead[]
  emailEvents        EmailEvent[]
  emailLogs          EmailLog[]

  @@index([userId])
  @@index([status])
}

model EmailCampaignLead {
  id             String          @id @default(cuid())
  campaignId     String
  leadId         String
  status         EmailLeadStatus @default(PENDING)
  sentAt         DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  repliedAt      DateTime?
  bouncedAt      DateTime?
  unsubscribedAt DateTime?
  errorMessage   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  campaign       EmailCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead           Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
  @@index([campaignId])
  @@index([leadId])
  @@index([status])
}

model EmailEvent {
  id         String         @id @default(cuid())
  campaignId String
  leadEmail  String
  eventType  EmailEventType
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime       @default(now())
  campaign   EmailCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([leadEmail])
  @@index([eventType])
}

model LeadActivity {
  id           String       @id @default(cuid())
  leadId       String
  activityType ActivityType
  description  String
  metadata     Json?
  userId       String?
  employeeId   String?
  dueDate      DateTime?
  completed    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @default(now()) @updatedAt
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])
  employee     Employee?    @relation("EmployeeLeadActivities", fields: [employeeId], references: [id])

  @@index([leadId])
  @@index([createdAt])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String
  variables String[] @default([])
  category  String?
  userId    String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@index([category])
}

model File {
  id           String   @id @default(cuid())
  name         String
  filename     String?
  originalName String?
  mimeType     String?
  size         Int
  url          String
  path         String?
  folder       String?  @default("default")
  isPublic     Boolean  @default(false)
  description  String?
  metadata     Json?
  userId       String
  uploadedBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailDraft {
  id             String      @id @default(cuid())
  userId         String
  leadId         String?
  companyName    String
  recipientEmail String?
  contactName    String?
  subject        String
  body           String
  tone           String?
  status         DraftStatus @default(DRAFT)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  planId                 String
  status                 SubscriptionStatus @default(ACTIVE)
  razorpaySubscriptionId String?            @unique
  razorpayCustomerId     String?
  currentPeriodStart     DateTime           @default(now())
  currentPeriodEnd       DateTime
  cancelAtPeriodEnd      Boolean            @default(false)
  canceledAt             DateTime?
  trialEndsAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  plan                   Plan               @relation(fields: [planId], references: [id])
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([razorpaySubscriptionId])
}

model Plan {
  id            String         @id @default(cuid())
  name          String         @unique
  displayName   String
  description   String?
  price         Int
  currency      String         @default("INR")
  interval      String
  features      Json
  modules       Json?
  maxLeads      Int            @default(20)
  maxEmails     Int            @default(50)
  maxCampaigns  Int            @default(5)
  isActive      Boolean        @default(true)
  stripePriceId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]

  @@index([name])
}

model UsageTracking {
  id               String   @id @default(cuid())
  userId           String   @unique
  leadsCreated     Int      @default(0)
  emailsSent       Int      @default(0)
  campaignsCreated Int      @default(0)
  lastResetAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  invoiceId         String?
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  razorpayPaymentId String?       @unique
  razorpayOrderId   String?
  razorpaySignature String?
  planId            String?
  description       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  invoice           Invoice?      @relation(fields: [invoiceId], references: [id])

  @@index([userId])
  @@index([invoiceId])
  @@index([razorpayPaymentId])
  @@index([status])
}

model EmailLog {
  id           String         @id @default(cuid())
  userId       String
  leadId       String?
  campaignId   String?
  to           String
  subject      String
  body         String?
  status       EmailLogStatus @default(PENDING)
  messageId    String?
  sentAt       DateTime?
  deliveredAt  DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  bouncedAt    DateTime?
  repliedAt    DateTime?
  replyBody    String?
  replySubject String?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  campaign     EmailCampaign? @relation(fields: [campaignId], references: [id])
  lead         Lead?          @relation(fields: [leadId], references: [id])
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leadId])
  @@index([campaignId])
  @@index([status])
  @@index([sentAt])
  @@index([messageId])
}

model EmailSequence {
  id          String               @id @default(cuid())
  userId      String
  name        String
  description String?
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments SequenceEnrollment[]
  steps       SequenceStep[]

  @@index([userId])
  @@index([isActive])
}

model SequenceStep {
  id         String        @id @default(cuid())
  sequenceId String
  stepNumber Int
  name       String
  delayDays  Int           @default(0)
  delayHours Int           @default(0)
  subject    String
  body       String
  condition  String?
  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, stepNumber])
  @@index([sequenceId])
}

model SequenceEnrollment {
  id             String        @id @default(cuid())
  sequenceId     String
  leadId         String
  currentStep    Int           @default(0)
  status         String        @default("ACTIVE")
  lastStepSentAt DateTime?
  nextStepDue    DateTime?
  completedAt    DateTime?
  stoppedReason  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lead           Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sequence       EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, leadId])
  @@index([nextStepDue])
  @@index([status])
  @@index([sequenceId])
  @@index([leadId])
}

model Task {
  id           String     @id @default(cuid())
  userId       String
  assignedToId String?
  leadId       String?
  dealId       String?
  title        String
  description  String?
  type         TaskType   @default(TODO)
  priority     Priority   @default(MEDIUM)
  status       TaskStatus @default(PENDING)
  dueDate      DateTime?
  reminderAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignedTo   User?      @relation("TaskAssignee", fields: [assignedToId], references: [id])
  deal         Deal?      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lead         Lead?      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user         User       @relation("TaskCreator", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assignedToId])
  @@index([leadId])
  @@index([dealId])
  @@index([dueDate])
  @@index([status])
  @@index([type])
}

model Deal {
  id                String          @id @default(cuid())
  userId            String
  assignedToId      String?
  leadId            String
  title             String
  value             Float           @default(0)
  currency          String          @default("USD")
  stage             DealStage       @default(PROSPECTING)
  probability       Int             @default(50)
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  lostReason        String?
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  calendarEvents    CalendarEvent[]
  assignedTo        User?           @relation("DealAssignee", fields: [assignedToId], references: [id])
  lead              Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user              User            @relation("DealCreator", fields: [userId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
  quotations        Quotation[]
  tasks             Task[]

  @@index([userId])
  @@index([assignedToId])
  @@index([leadId])
  @@index([stage])
  @@index([expectedCloseDate])
}

model LeadScore {
  id               String   @id @default(cuid())
  leadId           String   @unique
  totalScore       Int      @default(0)
  engagementScore  Int      @default(0)
  dataQualityScore Int      @default(0)
  fitScore         Int      @default(0)
  lastCalculatedAt DateTime @default(now())
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([totalScore])
  @@index([leadId])
}

model EmailQueue {
  id           String      @id @default(cuid())
  userId       String
  leadId       String?
  campaignId   String?
  sequenceId   String?
  priority     Int         @default(5)
  to           String
  subject      String
  body         String
  scheduledFor DateTime
  attempts     Int         @default(0)
  maxAttempts  Int         @default(3)
  status       QueueStatus @default(PENDING)
  sentAt       DateTime?
  errorMessage String?
  messageId    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
  @@index([scheduledFor])
  @@index([userId])
  @@index([priority])
}

model UnsubscribeList {
  id             String   @id @default(cuid())
  email          String   @unique
  userId         String?
  leadId         String?
  reason         String?
  source         String?
  unsubscribedAt DateTime @default(now())

  @@index([email])
  @@index([userId])
}

model Contact {
  id          String   @id @default(cuid())
  leadId      String
  firstName   String
  lastName    String
  email       String?
  phone       String?
  jobTitle    String?
  department  String?
  isPrimary   Boolean  @default(false)
  linkedinUrl String?
  twitterUrl  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([email])
  @@index([isPrimary])
}

model Workflow {
  id          String              @id @default(cuid())
  userId      String
  name        String
  description String?
  trigger     String
  conditions  Json
  actions     Json
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions  WorkflowExecution[]

  @@index([userId])
  @@index([isActive])
  @@index([trigger])
}

model WorkflowExecution {
  id         String   @id @default(cuid())
  workflowId String
  leadId     String?
  status     String
  result     Json?
  executedAt DateTime @default(now())
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([executedAt])
  @@index([status])
}

model CalendarEvent {
  id                 String            @id @default(cuid())
  userId             String
  leadId             String?
  dealId             String?
  title              String
  description        String?
  location           String?
  eventType          CalendarEventType @default(MEETING)
  startTime          DateTime
  endTime            DateTime
  allDay             Boolean           @default(false)
  attendees          Json?
  meetingLink        String?
  googleCalendarId   String?           @unique
  googleCalendarSync Boolean           @default(false)
  reminderMinutes    Int?
  status             CalendarStatus    @default(SCHEDULED)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deal               Deal?             @relation(fields: [dealId], references: [id])
  lead               Lead?             @relation(fields: [leadId], references: [id])
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leadId])
  @@index([dealId])
  @@index([startTime])
  @@index([status])
  @@index([googleCalendarId])
}

model Quotation {
  id              String          @id @default(cuid())
  quotationNumber String          @unique
  userId          String
  leadId          String?
  dealId          String?
  customerId      String?
  title           String
  description     String?
  validUntil      DateTime
  currency        String          @default("USD")
  subtotal        Float           @default(0)
  taxRate         Float           @default(0)
  taxAmount       Float           @default(0)
  discount        Float           @default(0)
  total           Float           @default(0)
  status          QuotationStatus @default(DRAFT)
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerAddress String?
  notes           String?
  terms           String?
  sentAt          DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  invoice         Invoice?
  customer        Customer?       @relation(fields: [customerId], references: [id])
  deal            Deal?           @relation(fields: [dealId], references: [id])
  lead            Lead?           @relation(fields: [leadId], references: [id])
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           QuotationItem[]

  @@index([userId])
  @@index([leadId])
  @@index([dealId])
  @@index([customerId])
  @@index([status])
  @@index([quotationNumber])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  name        String
  description String?
  quantity    Float     @default(1)
  unitPrice   Float
  amount      Float
  createdAt   DateTime  @default(now())
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  userId          String
  leadId          String?
  dealId          String?
  customerId      String?
  quotationId     String?       @unique
  title           String
  description     String?
  dueDate         DateTime
  currency        String        @default("USD")
  subtotal        Float         @default(0)
  taxRate         Float         @default(0)
  taxAmount       Float         @default(0)
  discount        Float         @default(0)
  total           Float         @default(0)
  amountPaid      Float         @default(0)
  amountDue       Float         @default(0)
  status          InvoiceStatus @default(DRAFT)
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerAddress String?
  paymentMethod   String?
  paymentDetails  String?
  notes           String?
  terms           String?
  sentAt          DateTime?
  viewedAt        DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  customer        Customer?     @relation(fields: [customerId], references: [id])
  deal            Deal?         @relation(fields: [dealId], references: [id])
  lead            Lead?         @relation(fields: [leadId], references: [id])
  quotation       Quotation?    @relation(fields: [quotationId], references: [id])
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           InvoiceItem[]
  payments        Payment[]

  @@index([userId])
  @@index([leadId])
  @@index([dealId])
  @@index([customerId])
  @@index([quotationId])
  @@index([status])
  @@index([invoiceNumber])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  name        String
  description String?
  quantity    Float    @default(1)
  unitPrice   Float
  amount      Float
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Customer {
  id                     String                  @id @default(cuid())
  /// Display name for the account (legacy DB column: hospitalName)
  organizationName       String                  @map("hospitalName")
  contactPerson          String
  email                  String?
  phone                  String?
  address                String?
  city                   String?
  state                  String?
  industry               String?
  accountType            String?
  companyId              String?
  notes                  String?
  /// Public one-click / QR service-request token (no login required)
  serviceRequestToken    String?                 @unique
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  activities             CustomerActivity[]
  contacts               CustomerContact[]
  equipmentInstallations EquipmentInstallation[]
  serviceContracts       ServiceContract[]
  invoices               Invoice[]
  quotations             Quotation[]
  supportTickets         SupportTicket[]
  liveChatSessions       LiveChatSession[]
  staff                  User[]                  @relation("CustomerStaff")
  notifications          Notification[]
  whatsappMessages       WhatsAppMessage[]
  company                Company?                @relation(fields: [companyId], references: [id])

  @@index([organizationName])
  @@index([city])
  @@index([industry])
  @@index([companyId])
  @@index([createdAt])
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  name       String
  role       String?
  email      String?
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model CustomerActivity {
  id          String   @id @default(cuid())
  customerId  String
  eventType   String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([createdAt])
}

model Product {
  id            String                  @id @default(cuid())
  name          String
  category      String?
  description   String?
  manufacturer  String?
  modelNumber   String?
  type          ProductType             @default(EQUIPMENT)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  installations EquipmentInstallation[]

  // ── Inventory & Stock Management (from Company Manager) ──
  sku              String?           @unique
  price            Float?
  quantity         Int               @default(0)
  companyId        String?
  imageUrl         String?
  barcode          String?           @unique
  maxQuantity      Int?
  minQuantity      Int               @default(0)
  qrCode           String?
  reorderPoint     Int               @default(0)
  supplierId       String?
  company          Company?          @relation(fields: [companyId], references: [id])
  supplier         Supplier?         @relation(fields: [supplierId], references: [id])
  batchItems       BatchItem[]
  inventoryRecords InventoryRecord[]
  purchaseOrders   PurchaseOrder[]   @relation("POProducts")
  salesOrders      SalesOrder[]      @relation("SOProducts")
  stockTransfers   StockTransfer[]
  locations        Location[]        @relation("ProductLocations")

  @@index([name])
  @@index([category])
  @@index([type])
  @@index([companyId])
  @@index([supplierId])
  @@index([sku])
}

model EquipmentInstallation {
  id                  String             @id @default(cuid())
  productId           String
  customerId          String
  serialNumber        String?
  installationDate    DateTime           @default(now())
  warrantyExpiry      DateTime?
  status              InstallationStatus @default(ACTIVE)
  notes               String?
  /// Equipment-scoped QR / one-click service-request token
  serviceRequestToken String?            @unique
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  customer            Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product             Product            @relation(fields: [productId], references: [id])
  tickets             SupportTicket[]
  serviceContracts    ServiceContract[]

  @@index([productId])
  @@index([customerId])
  @@index([serialNumber])
  @@index([status])
}

/// Annual / Comprehensive Maintenance Contracts (AMC / CMC) for service customers.
model ServiceContract {
  id                  String                @id @default(cuid())
  companyId           String
  customerId          String
  equipmentId         String?
  type                ServiceContractType   @default(AMC)
  status              ServiceContractStatus @default(ACTIVE)
  contractNumber      String?
  title               String
  startDate           DateTime
  endDate             DateTime
  /// Days before endDate to surface renewal alerts (default 45)
  reminderDays        Int                   @default(45)
  annualValue         Float?
  currency            String                @default("INR")
  /// CMC typically includes parts; AMC is labour/visits only
  includesParts       Boolean               @default(false)
  visitLimit          Int?
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  company             Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer            Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  equipment           EquipmentInstallation? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([customerId])
  @@index([equipmentId])
  @@index([endDate])
  @@index([status])
  @@index([type])
}

enum ServiceContractType {
  AMC
  CMC
}

enum ServiceContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CANCELLED
}

model SupportTicket {
  id                   String                  @id @default(cuid())
  customerId           String
  equipmentId          String?
  groupId              String?
  subject              String
  description          String
  priority             TicketPriority          @default(MEDIUM)
  status               TicketStatus            @default(OPEN)
  channel              TicketChannel           @default(PORTAL)
  ticketType           String?
  tags                 String[]                @default([])
  metadata             Json                    @default("{}")
  responseDueAt        DateTime?
  resolutionDueAt      DateTime?
  assignedTechnicianId String?
  csatRating           Int?
  csatComment          String?
  csatSubmittedAt      DateTime?
  mergedIntoId         String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  serviceReports       ServiceReport[]
  assignedTechnician   User?                   @relation("AssignedTickets", fields: [assignedTechnicianId], references: [id])
  customer             Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  equipment            EquipmentInstallation?  @relation(fields: [equipmentId], references: [id])
  group                SupportGroup?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  mergedInto           SupportTicket?          @relation("TicketMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom           SupportTicket[]         @relation("TicketMerge")
  liveChatSession      LiveChatSession?
  activities           TicketActivity[]
  transferHistory      TicketTransferHistory[]
  cashEntries          CashOnHandEntry[]
  travelExpenses       TravelExpense[]
  locationLogs         TechnicianLocationLog[]
  whatsappMessages     WhatsAppMessage[]

  @@index([customerId])
  @@index([equipmentId])
  @@index([groupId])
  @@index([assignedTechnicianId])
  @@index([status])
  @@index([priority])
  @@index([channel])
  @@index([createdAt])
  @@index([mergedIntoId])
}

model TicketActivity {
  id            String        @id @default(cuid())
  ticketId      String
  eventType     String
  description   String
  isInternal    Boolean       @default(false)
  performedById String?
  metadata      Json?
  createdAt     DateTime      @default(now())
  performedBy   User?         @relation("TicketActivities", fields: [performedById], references: [id])
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([isInternal])
  @@index([createdAt])
}

model TicketTransferHistory {
  id               String        @id @default(cuid())
  ticketId         String
  fromTechnicianId String?
  toTechnicianId   String
  reason           String?
  transferredAt    DateTime      @default(now())
  fromTechnician   User?         @relation("TransfersFrom", fields: [fromTechnicianId], references: [id])
  ticket           SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  toTechnician     User          @relation("TransfersTo", fields: [toTechnicianId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([fromTechnicianId])
  @@index([toTechnicianId])
}

// ── Help desk (Freshdesk-style) ───────────────────────────────────────────

model SupportGroup {
  id          String               @id @default(cuid())
  name        String
  description String?
  email       String?
  companyId   String?
  isDefault   Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  company     Company?             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members     SupportGroupMember[]
  tickets     SupportTicket[]

  @@index([companyId])
  @@index([isDefault])
}

model SupportGroupMember {
  id        String       @id @default(cuid())
  groupId   String
  userId    String
  createdAt DateTime     @default(now())
  group     SupportGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

model SupportCannedResponse {
  id          String   @id @default(cuid())
  title       String
  body        String   @db.Text
  category    String?
  isShared    Boolean  @default(true)
  createdById String?
  companyId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([category])
}

model KnowledgeArticle {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  content      String   @db.Text
  category     String?
  tags         String[] @default([])
  published    Boolean  @default(false)
  viewCount    Int      @default(0)
  helpfulCount Int      @default(0)
  companyId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([category])
  @@index([published])
}

model SlaPolicy {
  id              String         @id @default(cuid())
  name            String
  priority        TicketPriority
  responseHours   Int
  resolutionHours Int
  isDefault       Boolean        @default(true)
  companyId       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  company         Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, priority])
  @@index([companyId])
}

model LiveChatSession {
  id           String            @id @default(cuid())
  visitorToken String            @unique
  visitorName  String?
  visitorEmail String?
  customerId   String?
  ticketId     String?           @unique
  companyId    String?
  status       String            @default("OPEN")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  customer     Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  ticket       SupportTicket?    @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  company      Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages     LiveChatMessage[]

  @@index([companyId])
  @@index([status])
  @@index([customerId])
}

model LiveChatMessage {
  id        String          @id @default(cuid())
  sessionId String
  sender    String
  senderId  String?
  body      String          @db.Text
  createdAt DateTime        @default(now())
  session   LiveChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

model ServiceReport {
  id                  String        @id @default(cuid())
  ticketId            String
  technicianId        String
  serviceNotes        String
  partsReplaced       String?
  nextMaintenanceDate DateTime?
  attachments         Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  technician          User          @relation("ServiceReports", fields: [technicianId], references: [id], onDelete: Cascade)
  ticket              SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([technicianId])
}

model CashOnHandEntry {
  id           String         @id @default(cuid())
  userId       String
  technicianId String
  ticketId     String?
  entryType    CashEntryType
  amount       Float
  currency     String         @default("USD")
  description  String
  referenceNo  String?
  recordedAt   DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation("CashEntryCreator", fields: [userId], references: [id], onDelete: Cascade)
  technician   User           @relation("CashTechnician", fields: [technicianId], references: [id], onDelete: Cascade)
  ticket       SupportTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([technicianId])
  @@index([ticketId])
  @@index([entryType])
  @@index([recordedAt])
}

model TravelExpense {
  id              String                @id @default(cuid())
  userId          String
  technicianId    String
  ticketId        String?
  category        TravelExpenseCategory
  amount          Float
  currency        String                @default("USD")
  distanceKm      Float?
  fromLocation    String?
  toLocation      String?
  description     String
  expenseDate     DateTime              @default(now())
  status          ExpenseStatus         @default(PENDING)
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  receiptUrl      String?
  metadata        Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation("ExpenseCreator", fields: [userId], references: [id], onDelete: Cascade)
  technician      User                  @relation("TechnicianExpenses", fields: [technicianId], references: [id], onDelete: Cascade)
  approver        User?                 @relation("ExpenseApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  ticket          SupportTicket?        @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([technicianId])
  @@index([ticketId])
  @@index([status])
  @@index([category])
  @@index([expenseDate])
}

model TechnicianLocationLog {
  id           String         @id @default(cuid())
  technicianId String
  ticketId     String?
  latitude     Float
  longitude    Float
  accuracy     Float?
  speed        Float?
  heading      Float?
  source       GpsSource      @default(PWA)
  capturedAt   DateTime       @default(now())
  createdAt    DateTime       @default(now())
  technician   User           @relation("TechnicianLocations", fields: [technicianId], references: [id], onDelete: Cascade)
  ticket       SupportTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([technicianId])
  @@index([ticketId])
  @@index([capturedAt])
}

model WhatsAppMessage {
  id                String           @id @default(cuid())
  userId            String
  leadId            String?
  customerId        String?
  ticketId          String?
  channel           WhatsAppChannel
  direction         MessageDirection
  toPhone           String
  fromPhone         String?
  message           String
  status            WhatsAppStatus   @default(QUEUED)
  externalMessageId String?
  errorMessage      String?
  metadata          Json?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead              Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customer          Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  ticket            SupportTicket?   @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([leadId])
  @@index([customerId])
  @@index([ticketId])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
}

model WhatsAppProviderConfig {
  id                 String           @id @default(cuid())
  userId             String           @unique
  provider           WhatsAppProvider @default(DISABLED)
  twilioAccountSid   String?
  twilioAuthToken    String?
  twilioFromNumber   String?
  metaAccessToken    String?
  metaPhoneNumberId  String?
  metaBusinessId     String?
  metaApiVersion     String?          @default("v22.0")
  isActive           Boolean          @default(false)
  webhookVerifyToken String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([provider])
  @@index([isActive])
}

model FeatureModuleSetting {
  id        String        @id @default(cuid())
  userId    String
  module    FeatureModule
  enabled   Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
  @@index([module])
  @@index([enabled])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  resource     String
  resourceId   String?
  changes      Json?
  metadata     Json?
  status       String   @default("success")
  errorMessage String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model Role {
  id          String               @id @default(cuid())
  name        String               @unique
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  permissions RolePermission[]
  users       UserRoleAssignment[]

  @@index([name])
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@index([name])
}

model UserRoleAssignment {
  id        String    @id @default(cuid())
  userId    String
  roleId    String
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

